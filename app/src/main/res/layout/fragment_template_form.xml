<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/myWhite">

    <TextView
        android:id="@+id/tvHeader"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="Buat Template Tugas"
        android:textStyle="bold"
        android:textSize="18sp"
        android:gravity="center"
        android:textColor="@color/myBlack"
        android:layout_marginTop="24dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <com.google.android.material.card.MaterialCardView
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_margin="16dp"
        app:cardCornerRadius="20dp"
        app:cardElevation="2dp"
        app:layout_constraintTop_toBottomOf="@id/tvHeader"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- NAMA TEMPLATE -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Nama Template"
                android:textStyle="bold"/>

            <EditText
                android:id="@+id/etNamaTemplate"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:hint="Contoh: Pembersihan Harian"
                android:background="@drawable/bg_input_form"
                android:paddingHorizontal="12dp"
                android:layout_marginTop="8dp"/>

            <!-- LIST TASK -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="List Task (pisahkan enter)"
                android:textStyle="bold"
                android:layout_marginTop="16dp"/>

            <EditText
                android:id="@+id/etListTask"
                android:layout_width="match_parent"
                android:layout_height="120dp"
                android:hint="Cuci kamar\nCek AC\nRapikan tempat tidur"
                android:gravity="top"
                android:background="@drawable/bg_input_form"
                android:padding="12dp"
                android:layout_marginTop="8dp"
                android:inputType="textMultiLine"/>

            <!-- BUTTON SIMPAN -->
            <Button
                android:id="@+id/btnSimpanTemplate"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:text="Simpan Template"
                android:layout_marginTop="20dp"
                android:backgroundTint="@color/myBlueDark"
                android:textColor="@color/myWhite"/>

        </LinearLayout>

    </com.google.android.material.card.MaterialCardView>

</androidx.constraintlayout.widget.ConstraintLayout>