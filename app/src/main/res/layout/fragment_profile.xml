<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_gradient_home">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <!-- PROFILE CARD -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="24dp"
            app:cardElevation="6dp"
            app:cardBackgroundColor="@color/myWhite">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center"
                android:padding="24dp">

                <!-- FOTO -->
                <FrameLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content">

                    <com.google.android.material.imageview.ShapeableImageView
                        android:id="@+id/ivProfile"
                        android:layout_width="120dp"
                        android:layout_height="120dp"
                        android:scaleType="centerInside"
                        android:src="@drawable/ic_profile"
                        app:shapeAppearanceOverlay="@style/CircleImage"
                        app:strokeWidth="3dp"

                        app:strokeColor="@color/myBlueDark"/>
                    <!-- BUTTON EDIT FOTO -->
                    <com.google.android.material.card.MaterialCardView
                        android:id="@+id/btnEditFoto"
                        android:layout_width="36dp"
                        android:layout_height="36dp"
                        android:layout_gravity="bottom|end"
                        app:cardCornerRadius="18dp"
                        app:cardBackgroundColor="@color/myBlueDark"
                        app:cardElevation="4dp">

                        <ImageView
                            android:layout_width="18dp"
                            android:layout_height="18dp"
                            android:layout_gravity="center"
                            android:src="@android:drawable/ic_menu_camera"
                            app:tint="@color/myWhite"/>
                    </com.google.android.material.card.MaterialCardView>

                </FrameLayout>

                <!-- NAMA -->
                <TextView
                    android:id="@+id/tvNamaUser"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:text="Nama User"
                    android:textColor="@color/myBlack"
                    android:textSize="20sp"
                    android:textStyle="bold" />

                <!-- JABATAN -->
                <TextView
                    android:id="@+id/tvJabatanUser"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Manager"
                    android:textColor="#888888"
                    android:textSize="14sp"
                    android:layout_marginTop="4dp"/>

                <!-- EDIT BUTTON -->
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnEditProfile"
                    android:layout_width="wrap_content"
                    android:layout_height="44dp"
                    android:layout_marginTop="12dp"
                    android:text="Edit Profil"
                    android:textAllCaps="false"
                    android:textColor="@color/myBlueDark"
                    app:backgroundTint="@android:color/transparent"
                    app:strokeWidth="2dp"
                    app:strokeColor="@color/myBlueDark"
                    app:cornerRadius="20dp"/>

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- LOGOUT -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnLogout"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginTop="24dp"
            android:text="Log Out"
            android:textAllCaps="false"
            android:textColor="@android:color/white"
            app:backgroundTint="#E53935"
            app:cornerRadius="14dp"/>

    </LinearLayout>
</ScrollView>