<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F8F9FF">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <!-- HEADER -->
        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginBottom="16dp">

            <ImageButton
                android:id="@+id/btnBack"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:layout_centerVertical="true"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:src="@drawable/ic_back" />

            <TextView
                android:id="@+id/tvTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_centerInParent="true"
                android:text="Tambah Data Staff"
                android:textColor="#5E5E9E"
                android:textSize="20sp"
                android:textStyle="bold" />
        </RelativeLayout>

        <!-- CARD -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="20dp"
            app:cardElevation="4dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="24dp">

                <!-- FOTO -->
                <ImageView
                    android:id="@+id/ivFotoStaff"
                    android:layout_width="120dp"
                    android:layout_height="120dp"
                    android:layout_gravity="center"
                    android:layout_marginBottom="16dp"
                    android:background="@drawable/bg_input_field"
                    android:scaleType="centerCrop"
                    android:src="@drawable/ic_profile" />

                <!-- NAMA -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Nama Lengkap"
                    android:textStyle="bold" />

                <EditText
                    android:id="@+id/etNamaStaff"
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:layout_marginTop="6dp"
                    android:layout_marginBottom="12dp"
                    android:background="@drawable/bg_input_field"
                    android:paddingStart="16dp" />

                <!-- TELEPON -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Telepon"
                    android:textStyle="bold"/>

                <EditText
                    android:id="@+id/etTeleponStaff"
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:layout_marginTop="6dp"
                    android:layout_marginBottom="12dp"
                    android:background="@drawable/bg_input_field"
                    android:inputType="phone"
                    android:paddingStart="16dp"/>

                <!-- EMAIL -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Email"
                    android:textStyle="bold"/>

                <EditText
                    android:id="@+id/etEmailStaff"
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:layout_marginTop="6dp"
                    android:layout_marginBottom="12dp"
                    android:background="@drawable/bg_input_field"
                    android:inputType="textEmailAddress"
                    android:paddingStart="16dp"/>

                <!-- POSISI -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Posisi"
                    android:textStyle="bold"/>

                <EditText
                    android:id="@+id/etPosisiStaff"
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:layout_marginTop="6dp"
                    android:layout_marginBottom="12dp"
                    android:background="@drawable/bg_input_field"
                    android:paddingStart="16dp"/>

                <!-- PASSWORD -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Password"
                    android:textStyle="bold"/>

                <EditText
                    android:id="@+id/etPasswordStaff"
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:layout_marginTop="6dp"
                    android:layout_marginBottom="12dp"
                    android:background="@drawable/bg_input_field"
                    android:inputType="textPassword"
                    android:paddingStart="16dp"/>

                <!-- STATUS -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Status Staff"
                    android:textStyle="bold"/>

                <Switch
                    android:id="@+id/swStatusStaff"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="16dp"
                    android:text="Aktif / Nonaktif"/>

                <!-- BUTTON -->
                <Button
                    android:id="@+id/btnSimpanStaff"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:backgroundTint="#C13852"
                    android:text="Simpan Data Staff"
                    android:textAllCaps="false"
                    android:textStyle="bold"
                    app:cornerRadius="12dp" />

            </LinearLayout>
        </androidx.cardview.widget.CardView>

    </LinearLayout>
</ScrollView>