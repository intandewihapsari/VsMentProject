<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/myWhite">

    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="16dp">
        <ImageButton
            android:id="@+id/btnBack"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:src="@drawable/ic_back"
            android:background="?attr/selectableItemBackgroundBorderless"
            app:tint="@color/myBlack" />
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_centerInParent="true"
            android:text="Detail Laporan"
            android:textStyle="bold"
            android:textSize="18sp"
            android:textColor="@color/myBlack"/>
    </RelativeLayout>

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardTipe"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp"
                app:strokeWidth="1dp"
                app:strokeColor="#EEE">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="16dp"
                    android:gravity="center">
                    <TextView
                        android:id="@+id/tvTipeBesar"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="TIPE LAPORAN"
                        android:textSize="20sp"
                        android:textStyle="bold"/>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="220dp"
                android:layout_marginTop="16dp"
                app:cardCornerRadius="16dp">
                <ImageView
                    android:id="@+id/imgBukti"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:scaleType="centerCrop"
                    android:src="@drawable/ic_profile_deffault" />
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="2dp">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">
                    <TextView
                        android:id="@+id/tvStatusDetail"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="STATUS"
                        android:paddingHorizontal="8dp"
                        android:paddingVertical="4dp"
                        android:background="@drawable/bg_status"
                        android:textSize="12sp"
                        android:textColor="@color/myWhite"
                        android:layout_marginBottom="8dp"/>
                    <TextView android:id="@+id/tvBarang" android:layout_width="match_parent" android:layout_height="wrap_content" android:textSize="18sp" android:textStyle="bold" android:textColor="@color/myBlack"/>
                    <TextView android:id="@+id/tvVilla" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="4dp"/>
                    <TextView android:id="@+id/tvArea" android:layout_width="match_parent" android:layout_height="wrap_content"/>
                    <TextView android:id="@+id/tvStaff" android:layout_width="match_parent" android:layout_height="wrap_content"/>
                    <TextView android:id="@+id/tvWaktu" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="8dp" android:textSize="12sp"/>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Deskripsi Laporan"
                android:layout_marginTop="16dp"
                android:layout_marginStart="4dp"
                android:textStyle="bold"
                android:gravity="top"
                />
            <TextView
                android:id="@+id/tvDeskripsi"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:padding="12dp"
                android:background="@color/myWhite" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Catatan Manager (Edit)"
                android:layout_marginTop="16dp"
                android:layout_marginStart="4dp"
                android:textStyle="bold"
                android:textColor="@color/myBlueDark"/>
            <EditText
                android:id="@+id/etCatatanManager"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:minHeight="100dp"
                android:layout_marginTop="8dp"
                android:gravity="top"
                android:padding="12dp"
                android:hint="Tulis instruksi atau catatan di sini..."
                android:background="@color/myWhite"
                android:textSize="14sp"/>


            <Button
                android:id="@+id/btnSimpanCatatan"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:text="Simpan Catatan"
                android:backgroundTint="@color/myBlueDark"
                app:cornerRadius="12dp"/>

            <Button
                android:id="@+id/btnSelesaikanLaporan"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="Tandai Selesai"
                android:textColor="@color/myGreen"
                android:backgroundTint="@color/myGreenDark"
                app:cornerRadius="12dp"
                android:visibility="gone"/>
        </LinearLayout>
    </androidx.core.widget.NestedScrollView>
</LinearLayout>